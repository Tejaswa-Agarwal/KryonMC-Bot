<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Axion Dashboard</title>
  <link rel="icon" type="image/png" href="/img/axion-logo.png">
  <link rel="stylesheet" href="/css/main.css">
</head>
<body>
  <main class="container layout">
    <aside class="sidebar">
      <div class="logo-wrap">
        <img class="logo" src="/img/axion-logo.png" onerror="this.onerror=null;this.src='/img/axion-logo.svg';" alt="Axion">
        <div>
          <div class="brand-title">AXION</div>
          <div class="brand-sub">Control Center</div>
        </div>
      </div>
      <div class="theme-picker">
        <button class="theme-btn" data-theme="default">Default</button>
        <button class="theme-btn" data-theme="neon">Neon</button>
        <button class="theme-btn" data-theme="sunset">Sunset</button>
        <button class="theme-btn" data-theme="emerald">Emerald</button>
      </div>
    </aside>

    <section class="main">
      <section class="hero">
        <h1>Axion Control Center</h1>
        <p>Modern moderation dashboard with themes, smooth UI, and fast server control.</p>
        <div class="actions">
          <% if (user) { %>
            <a class="btn" href="/dashboard">Open Dashboard</a>
            <a class="btn secondary" href="/logout">Logout</a>
          <% } else { %>
            <a class="btn" href="/login">Login with Discord</a>
          <% } %>
        </div>
      </section>

      <section class="card">
        <h2>Setup</h2>
        <p class="muted">Upload your logo to <code>dashboard/public/img/axion-logo.png</code> to replace placeholder instantly.</p>
        <pre><code>ENABLE_DASHBOARD=true
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=25575
DASHBOARD_CALLBACK=https://your-domain.com/callback</code></pre>
      </section>
    </section>
  </main>
  <script src="/js/theme.js"></script>
</body>
</html>
