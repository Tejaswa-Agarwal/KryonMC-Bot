<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Axion Dashboard</title>
  <link rel="icon" type="image/png" href="/img/axion-logo.png">
  <link rel="stylesheet" href="/css/main.css?v=20260329-6">
</head>
<body>
  <main class="container layout">
    <aside class="sidebar">
      <div class="logo-wrap">
        <img class="logo" style="width:24px;height:24px;max-width:24px;max-height:24px;min-width:24px;min-height:24px;object-fit:cover;border-radius:6px;" src="/img/axion-logo.png" onerror="this.onerror=null;this.src='/img/axion-logo.svg';" alt="Axion">
        <div>
          <div class="brand-title">AXION</div>
          <div class="brand-sub">Control Center</div>
        </div>
      </div>
      <div class="theme-picker">
        <button class="theme-btn" data-theme="default">Default</button>
        <button class="theme-btn" data-theme="neon">Neon</button>
        <button class="theme-btn" data-theme="sunset">Sunset</button>
        <button class="theme-btn" data-theme="emerald">Emerald</button>
      </div>
    </aside>

    <section class="main">
      <section class="hero">
        <h1>Axion Control Center</h1>
        <p>Modern moderation dashboard with themes, live analytics, automod, tickets, reaction roles, and multi-guild controls.</p>
        <div class="actions">
          <% if (user) { %>
            <a class="btn" href="/dashboard">Open Dashboard</a>
            <a class="btn secondary" href="/logout">Logout</a>
          <% } else { %>
            <a class="btn" href="/login">Login with Discord</a>
          <% } %>
          <a class="btn ghost" href="<%= inviteUrl %>" target="_blank" rel="noopener">Invite Axion</a>
        </div>
      </section>

      <section class="card">
        <h2>About Axion</h2>
        <section class="grid cols-3">
          <div class="card"><h3>Servers</h3><div class="metric"><%= bot?.guildCount || 0 %></div></div>
          <div class="card"><h3>Slash Commands</h3><div class="metric"><%= bot?.commandCount || 0 %></div></div>
          <div class="card"><h3>Identity</h3><p class="muted"><%= bot?.tag || 'Axion' %></p></div>
        </section>
        <p class="muted" style="margin-top:10px;">Axion supports advanced moderation, case tracking, automod filters, logging, tickets, reaction roles, starboard, verification, tags, and notes.</p>
      </section>
    </section>
  </main>
  <script src="/js/theme.js?v=20260329-6"></script>
</body>
</html>
