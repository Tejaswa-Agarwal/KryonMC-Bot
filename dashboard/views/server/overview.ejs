<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= guild.name %> · Axion</title>
  <link rel="icon" type="image/png" href="/img/axion-logo.png">
  <link rel="stylesheet" href="/css/main.css?v=20260329-11">
</head>
<body>
  <main class="container layout">
    <aside class="sidebar">
      <div class="logo-wrap">
        <div class="logo-left">
          <img class="logo" style="width:24px;height:24px;max-width:24px;max-height:24px;min-width:24px;min-height:24px;object-fit:cover;border-radius:6px;" src="/img/axion-logo.png" onerror="this.onerror=null;this.src='/img/axion-logo.svg';" alt="Axion">
          <div class="brand-text">
            <div class="brand-title">AXION</div>
            <div class="brand-sub"><%= guild.name %></div>
          </div>
        </div>
        <button class="icon-btn" data-sidebar-toggle>☰</button>
      </div>
      <nav class="nav">
        <a class="nav-link" href="/dashboard"><i>🏠</i><span>Servers</span></a>
        <a class="nav-link active" href="#"><i>⚙️</i><span>Config</span></a>
      </nav>
      <div class="theme-picker">
        <button class="theme-btn" data-theme="default">Default</button>
        <button class="theme-btn" data-theme="wick">Wick</button>
        <button class="theme-btn" data-theme="neon">Neon</button>
        <button class="theme-btn" data-theme="sunset">Sunset</button>
        <button class="theme-btn" data-theme="emerald">Emerald</button>
      </div>
    </aside>

    <section class="main">
      <section class="hero">
        <h1><%= guild.name %> Configuration</h1>
        <p>Manage your server modules, permissions, and moderation setup.</p>
        <div class="actions"><a class="btn secondary" href="/dashboard">Back</a></div>
      </section>

      <section class="card compact-overview">
        <div class="compact-overview-item">
          <span>Total cases</span>
          <strong id="stat-cases">0</strong>
        </div>
        <div class="compact-overview-item">
          <span>Total warnings</span>
          <strong id="stat-warnings">0</strong>
        </div>
        <div class="compact-overview-item">
          <span>Open tickets</span>
          <strong id="stat-tickets">0</strong>
        </div>
      </section>

      <section class="card">
        <h2>Server Health</h2>
        <div id="health-summary" class="grid cols-3"></div>
      </section>

      <section class="card">
        <h2>Moderation Trend</h2>
        <div id="case-chart" class="grid cols-3"></div>
      </section>

      <section class="card">
        <h2>Modules</h2>
        <div class="tab-row" data-tab-group="modules">
          <button class="tab-btn active" data-tab-group="modules" data-tab-btn="roles">Roles</button>
          <button class="tab-btn" data-tab-group="modules" data-tab-btn="owners">Extra Owners</button>
          <button class="tab-btn" data-tab-group="modules" data-tab-btn="welcomer">Welcomer</button>
          <button class="tab-btn" data-tab-group="modules" data-tab-btn="starboard">Starboard</button>
          <button class="tab-btn" data-tab-group="modules" data-tab-btn="automod">Automod</button>
          <button class="tab-btn" data-tab-group="modules" data-tab-btn="rolesmenu">Role Menus</button>
          <button class="tab-btn" data-tab-group="modules" data-tab-btn="antinuke">Anti-Nuke</button>
          <button class="tab-btn" data-tab-group="modules" data-tab-btn="security">Security Shield</button>
          <button class="tab-btn" data-tab-group="modules" data-tab-btn="responder">Auto Responder</button>
          <button class="tab-btn" data-tab-group="modules" data-tab-btn="tags">Tags</button>
          <button class="tab-btn" data-tab-group="modules" data-tab-btn="backup">Backup</button>
          <button class="tab-btn" data-tab-group="modules" data-tab-btn="logging">Logging</button>
          <button class="tab-btn" data-tab-group="modules" data-tab-btn="systems">Systems</button>
        </div>
      </section>

      <section class="card tab-panel active" data-tab-group="modules" data-tab-panel="roles">
        <h2>Role Configuration</h2>
        <label>Moderator Role</label><select id="moderatorRoleId"></select>
        <label>Admin Role</label><select id="adminRoleId"></select>
        <button class="btn" onclick="handleSave(this,'roleConfig',{ moderatorRoleId: val('moderatorRoleId'), adminRoleId: val('adminRoleId') })">Save Roles</button>
      </section>

      <section class="card tab-panel" data-tab-group="modules" data-tab-panel="owners">
        <h2>Extra Owners</h2>
        <p class="muted">Extra owners get owner-level Axion permissions in this guild.</p>
        <label>User IDs (comma separated)</label>
        <textarea id="extraOwnersUserIds" rows="3" placeholder="123456789012345678, 987654321098765432"></textarea>
        <button class="btn" onclick="saveExtraOwners(this)">Save Extra Owners</button>
      </section>

      <section class="card tab-panel" data-tab-group="modules" data-tab-panel="welcomer">
        <h2>Welcomer</h2>
        <label>Enabled</label><select id="welcomerEnabled"><option value="true">true</option><option value="false">false</option></select>
        <label>Channel</label><select id="welcomerChannelId"></select>
        <label>Message</label><textarea id="welcomerMessage" rows="3" placeholder="Welcome {user} to {server}!"></textarea>
        <button class="btn" onclick="handleSave(this,'welcomerConfig',{ enabled: boolVal('welcomerEnabled'), channelId: val('welcomerChannelId'), message: val('welcomerMessage') })">Save Welcomer</button>
      </section>

      <section class="card tab-panel" data-tab-group="modules" data-tab-panel="starboard">
        <h2>Starboard</h2>
        <label>Enabled</label><select id="starboardEnabled"><option value="true">true</option><option value="false">false</option></select>
        <label>Channel</label><select id="starboardChannelId"></select>
        <label>Threshold</label><input id="starboardThreshold" type="number" min="1" max="20" value="3" />
        <button class="btn" onclick="handleSave(this,'starboardConfig',{ enabled: boolVal('starboardEnabled'), channelId: val('starboardChannelId'), threshold: numVal('starboardThreshold') })">Save Starboard</button>
      </section>

      <section class="card tab-panel" data-tab-group="modules" data-tab-panel="automod">
        <h2>Automod</h2>
        <label>Enabled</label><select id="automodEnabled"><option value="true">true</option><option value="false">false</option></select>
        <label>Punishment</label>
        <select id="automodPunishment">
          <option value="warn">warn</option>
          <option value="timeout">timeout</option>
          <option value="kick">kick</option>
          <option value="ban">ban</option>
        </select>
        <label>Anti Spam</label><select id="automodAntiSpam"><option value="true">true</option><option value="false">false</option></select>
        <label>Max Messages (window)</label><input id="automodMaxMessages" type="number" min="2" max="20" value="5" />
        <label>Spam Window Seconds</label><input id="automodTimeWindow" type="number" min="2" max="60" value="5" />
        <label>Anti Invite</label><select id="automodAntiInvite"><option value="true">true</option><option value="false">false</option></select>
        <label>Blocked Domains (comma separated)</label><textarea id="automodBlockedDomains" rows="2" placeholder="example.com, badsite.net"></textarea>
        <label>Regex Filters (comma separated patterns)</label><textarea id="automodRegexFilters" rows="2" placeholder="free\\s+nitro, (buy|sell)\\s+account"></textarea>
        <label>Anti Caps</label><select id="automodAntiCaps"><option value="true">true</option><option value="false">false</option></select>
        <label>Caps Threshold %</label><input id="automodCapsThreshold" type="number" min="40" max="100" value="70" />
        <label>Anti Mass Mention</label><select id="automodAntiMention"><option value="true">true</option><option value="false">false</option></select>
        <label>Max Mentions</label><input id="automodMaxMentions" type="number" min="2" max="20" value="5" />
        <label>Anti Emoji Spam</label><select id="automodAntiEmoji"><option value="true">true</option><option value="false">false</option></select>
        <label>Max Emojis</label><input id="automodMaxEmojis" type="number" min="2" max="30" value="10" />
        <label>Bypass Admins</label><select id="automodBypassAdmins"><option value="true">true</option><option value="false">false</option></select>
        <label>Bypass Moderators</label><select id="automodBypassModerators"><option value="true">true</option><option value="false">false</option></select>
        <label>Bypass Bots</label><select id="automodBypassBots"><option value="true">true</option><option value="false">false</option></select>
        <button class="btn" onclick="saveAutomod(this)">Save Automod</button>
      </section>

      <section class="card tab-panel" data-tab-group="modules" data-tab-panel="rolesmenu">
        <h2>Role Menus & Buttons Builder</h2>
        <p class="muted">Edit reaction role mappings as JSON. Format: messageId -> { mode, roles }.</p>
        <textarea id="reactionRoleConfigJson" rows="10" placeholder='{"123456789012345678":{"mode":"normal","roles":{"✅":"987654321098765432"}}}'></textarea>
        <button class="btn" onclick="saveRoleMenus(this)">Save Role Menus</button>
      </section>

      <section class="card tab-panel" data-tab-group="modules" data-tab-panel="antinuke">
        <h2>Anti-Nuke</h2>
        <p class="muted">Protect against destructive raid/admin abuse like rapid role/channel creation/deletion.</p>
        <label>Enabled</label><select id="antiNukeEnabled"><option value="true">true</option><option value="false">false</option></select>
        <label>Preset</label>
        <select id="antiNukePreset">
          <option value="strict">strict</option>
          <option value="medium">medium</option>
          <option value="custom">custom</option>
        </select>
        <label>Action Threshold</label><input id="antiNukeThreshold" type="number" min="2" max="20" value="3" />
        <label>Window Seconds</label><input id="antiNukeWindow" type="number" min="5" max="120" value="10" />
        <label>Response Action</label>
        <select id="antiNukeAction">
          <option value="remove_roles">remove_roles</option>
          <option value="kick">kick</option>
          <option value="ban">ban</option>
        </select>
        <label>Apply To Admins</label><select id="antiNukeApplyToAdmins"><option value="false">false</option><option value="true">true</option></select>
        <label>Whitelisted User IDs (comma separated)</label>
        <textarea id="antiNukeUsers" rows="2" placeholder="1234567890, 0987654321"></textarea>
        <label>Whitelisted Role IDs (comma separated)</label>
        <textarea id="antiNukeRoles" rows="2" placeholder="1111111111, 2222222222"></textarea>
        <button class="btn" onclick="saveAntiNuke(this)">Save Anti-Nuke</button>
      </section>

      <section class="card tab-panel" data-tab-group="modules" data-tab-panel="security">
        <h2>Security Shield</h2>
        <p class="muted">Join raid and alt-account protection with automatic actions.</p>
        <label>Enabled</label><select id="securityEnabled"><option value="true">true</option><option value="false">false</option></select>
        <label>Anti-Alt Enabled</label><select id="securityAntiAltEnabled"><option value="true">true</option><option value="false">false</option></select>
        <label>Minimum Account Age (days)</label><input id="securityMinAge" type="number" min="1" max="90" value="3" />
        <label>Anti-Alt Action</label>
        <select id="securityAntiAltAction">
          <option value="kick">kick</option>
          <option value="quarantine">quarantine</option>
          <option value="alert">alert</option>
        </select>
        <label>Quarantine Role ID</label><input id="securityQuarantineRoleId" type="text" placeholder="123456789012345678" />
        <label>Join Guard Enabled</label><select id="securityJoinGuardEnabled"><option value="true">true</option><option value="false">false</option></select>
        <label>Join Threshold</label><input id="securityJoinThreshold" type="number" min="3" max="50" value="8" />
        <label>Join Window Seconds</label><input id="securityJoinWindow" type="number" min="5" max="120" value="15" />
        <label>Join Guard Action</label>
        <select id="securityJoinAction">
          <option value="alert">alert</option>
          <option value="kick">kick</option>
        </select>
        <button class="btn" onclick="saveSecurityShield(this)">Save Security Shield</button>
      </section>

      <section class="card tab-panel" data-tab-group="modules" data-tab-panel="responder">
        <h2>Auto Responder</h2>
        <label>Enabled</label><select id="autoResponderEnabled"><option value="true">true</option><option value="false">false</option></select>
        <label>Responders (JSON array)</label>
        <textarea id="autoResponderRules" rows="6" placeholder='[{"trigger":"hello","response":"Hi!","mode":"contains"}]'></textarea>
        <button class="btn" onclick="saveAutoResponder(this)">Save Auto Responder</button>
      </section>

      <section class="card tab-panel" data-tab-group="modules" data-tab-panel="tags">
        <h2>Custom Tags</h2>
        <label>Tags (JSON object: name -> content)</label>
        <textarea id="tagsMap" rows="8" placeholder='{"rules":"Read #rules first","support":"Open a ticket"}'></textarea>
        <button class="btn" onclick="saveTagsMap(this)">Save Tags</button>
      </section>

      <section class="card tab-panel" data-tab-group="modules" data-tab-panel="backup">
        <h2>Backup & Restore</h2>
        <p class="muted">Create point-in-time snapshots of this guild configuration and restore when needed.</p>
        <button class="btn" onclick="createBackup(this)">Create Backup</button>
        <label>Available Backups</label>
        <select id="backupIdSelect"></select>
        <button class="btn secondary" onclick="restoreBackup(this)">Restore Selected Backup</button>
      </section>

      <section class="card tab-panel" data-tab-group="modules" data-tab-panel="logging">
        <h2>Logging</h2>
        <label>Moderation Log Channel</label><select id="modLog"></select>
        <label>Message Log Channel</label><select id="messageLog"></select>
        <button class="btn" onclick="handleSave(this,'logConfig',{ modLog: val('modLog'), messageLog: val('messageLog') })">Save Logging</button>
      </section>

      <section class="card tab-panel" data-tab-group="modules" data-tab-panel="systems">
        <h2>Systems Control</h2>
        <p class="muted">Enable core systems from one place, then fine-tune them in their dedicated commands.</p>
        <label>Suggestions</label><select id="suggestionsEnabled"><option value="true">true</option><option value="false">false</option></select>
        <label>Verification</label><select id="verificationEnabled"><option value="true">true</option><option value="false">false</option></select>
        <label>Verification Mode</label>
        <select id="verificationMode">
          <option value="button">button</option>
          <option value="captcha">captcha</option>
          <option value="human">human-check</option>
        </select>
        <label>Human-Check Question</label><input id="verificationQuestion" type="text" placeholder="Type YES to verify." />
        <label>Human-Check Answer</label><input id="verificationAnswer" type="text" placeholder="YES" />
        <label>Ticket System</label><select id="ticketEnabled"><option value="true">true</option><option value="false">false</option></select>
        <button class="btn" onclick="saveSystems(this)">Save Systems</button>
      </section>

      <section class="card">
        <h2>Recent Activity</h2>
        <div id="activity-feed" class="grid"></div>
      </section>
    </section>
  </main>

  <script src="/js/theme.js?v=20260329-12"></script>
  <script src="/js/ui.js?v=20260329-12"></script>
  <script>
    const guildId = '<%= guild.id %>';

    function val(id) { return document.getElementById(id).value; }
    function boolVal(id) { return document.getElementById(id).value === 'true'; }
    function numVal(id) { return Number(document.getElementById(id).value); }
    function csvToArray(id) {
      return val(id).split(',').map(v => v.trim()).filter(Boolean);
    }
    function arrayToCsv(list) {
      return Array.isArray(list) ? list.join(', ') : '';
    }
    function healthPill(label, ok) {
      return `<div class="card mini-health ${ok ? 'ok' : 'warning'}"><h3>${label}</h3><p class="muted">${ok ? 'Configured' : 'Needs setup'}</p></div>`;
    }

    function fillSelect(id, options, selected) {
      const el = document.getElementById(id);
      if (!el) return;
      const base = '<option value="">Not set</option>';
      el.innerHTML = base + options.map(o => `<option value="${o.id}">${o.name}</option>`).join('');
      if (selected) el.value = selected;
    }

    async function handleSave(btn, section, data) {
      window.axionSetSaving(btn, true);
      try {
        const res = await fetch(`/api/guild/${guildId}/config`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ section, data }),
        });
        const payload = await res.json();
        if (!res.ok) throw new Error(payload.error || 'Save failed');
        window.axionToast(`${section} saved`, 'ok');
      } catch (err) {
        window.axionToast(err.message, 'danger');
      } finally {
        window.axionSetSaving(btn, false);
      }
    }

    async function saveSystems(btn) {
      window.axionSetSaving(btn, true);
      try {
        const payloads = [
          fetch(`/api/guild/${guildId}/config`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
              section: 'suggestionConfig',
              data: { enabled: boolVal('suggestionsEnabled') },
            }),
          }),
          fetch(`/api/guild/${guildId}/config`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
              section: 'verifyConfig',
              data: {
                enabled: boolVal('verificationEnabled'),
                mode: val('verificationMode'),
                humanCheck: {
                  question: val('verificationQuestion') || 'Type YES to verify.',
                  answer: val('verificationAnswer') || 'YES'
                }
              },
            }),
          }),
          fetch(`/api/guild/${guildId}/config`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
              section: 'ticketConfig',
              data: { enabled: boolVal('ticketEnabled') },
            }),
          }),
        ];

        const results = await Promise.all(payloads);
        const bad = results.find(r => !r.ok);
        if (bad) throw new Error('Could not save one or more systems');
        window.axionToast('Systems updated', 'ok');
      } catch (err) {
        window.axionToast(err.message, 'danger');
      } finally {
        window.axionSetSaving(btn, false);
      }
    }

    async function saveAutomod(btn) {
      const payload = {
        enabled: boolVal('automodEnabled'),
        punishment: val('automodPunishment'),
        antiSpam: {
          enabled: boolVal('automodAntiSpam'),
          maxMessages: numVal('automodMaxMessages'),
          timeWindow: numVal('automodTimeWindow') * 1000,
        },
        antiInvite: {
          enabled: boolVal('automodAntiInvite'),
        },
        blockedDomains: csvToArray('automodBlockedDomains').map(v => v.toLowerCase()),
        regexFilters: csvToArray('automodRegexFilters'),
        antiCaps: {
          enabled: boolVal('automodAntiCaps'),
          threshold: numVal('automodCapsThreshold'),
          minLength: 10,
        },
        antiMassMention: {
          enabled: boolVal('automodAntiMention'),
          max: numVal('automodMaxMentions'),
        },
        antiEmoji: {
          enabled: boolVal('automodAntiEmoji'),
          max: numVal('automodMaxEmojis'),
        },
        bypass: {
          admins: boolVal('automodBypassAdmins'),
          moderators: boolVal('automodBypassModerators'),
          bots: boolVal('automodBypassBots'),
        },
      };
      await handleSave(btn, 'automodConfig', payload);
    }

    async function saveAntiNuke(btn) {
      const preset = val('antiNukePreset');
      const presetProfiles = {
        strict: { threshold: 2, window: 8, action: 'ban', applyToAdmins: true },
        medium: { threshold: 3, window: 10, action: 'kick', applyToAdmins: false },
      };
      const profile = presetProfiles[preset];
      const payload = {
        enabled: boolVal('antiNukeEnabled'),
        preset,
        threshold: profile ? profile.threshold : numVal('antiNukeThreshold'),
        intervalMs: (profile ? profile.window : numVal('antiNukeWindow')) * 1000,
        action: profile ? profile.action : val('antiNukeAction'),
        applyToAdmins: profile ? profile.applyToAdmins : boolVal('antiNukeApplyToAdmins'),
        whitelistedUsers: csvToArray('antiNukeUsers'),
        whitelistedRoles: csvToArray('antiNukeRoles'),
      };
      await handleSave(btn, 'antiNukeConfig', payload);
    }

    async function saveSecurityShield(btn) {
      const quarantineRoleId = val('securityQuarantineRoleId').trim();
      const payload = {
        enabled: boolVal('securityEnabled'),
        quarantineRoleId: quarantineRoleId || null,
        antiAlt: {
          enabled: boolVal('securityAntiAltEnabled'),
          minAccountAgeDays: numVal('securityMinAge'),
          action: val('securityAntiAltAction'),
        },
        joinGuard: {
          enabled: boolVal('securityJoinGuardEnabled'),
          maxJoins: numVal('securityJoinThreshold'),
          windowMs: numVal('securityJoinWindow') * 1000,
          action: val('securityJoinAction'),
        },
      };
      await handleSave(btn, 'securityShieldConfig', payload);
    }

    async function saveExtraOwners(btn) {
      const payload = {
        userIds: csvToArray('extraOwnersUserIds'),
      };
      await handleSave(btn, 'extraOwnersConfig', payload);
    }

    async function saveAutoResponder(btn) {
      let responders = [];
      try {
        responders = JSON.parse(val('autoResponderRules') || '[]');
        if (!Array.isArray(responders)) throw new Error('Rules must be an array');
      } catch (err) {
        window.axionToast(`Invalid responder JSON: ${err.message}`, 'danger');
        return;
      }
      await handleSave(btn, 'autoResponderConfig', {
        enabled: boolVal('autoResponderEnabled'),
        responders
      });
    }

    async function saveTagsMap(btn) {
      let tagsMap = {};
      try {
        tagsMap = JSON.parse(val('tagsMap') || '{}');
        if (typeof tagsMap !== 'object' || Array.isArray(tagsMap)) throw new Error('Tags must be an object');
      } catch (err) {
        window.axionToast(`Invalid tags JSON: ${err.message}`, 'danger');
        return;
      }
      const tags = Object.entries(tagsMap).reduce((acc, [name, content]) => {
        acc[String(name).toLowerCase()] = {
          content: String(content),
          authorId: 'dashboard',
          createdAt: Date.now(),
          uses: 0,
        };
        return acc;
      }, {});
      await handleSave(btn, 'tagsConfig', { tags });
    }

    async function saveRoleMenus(btn) {
      let payload = {};
      try {
        payload = JSON.parse(val('reactionRoleConfigJson') || '{}');
        if (typeof payload !== 'object' || Array.isArray(payload)) throw new Error('Role menu config must be an object');
      } catch (err) {
        window.axionToast(`Invalid role menu JSON: ${err.message}`, 'danger');
        return;
      }
      await handleSave(btn, 'reactionRoleConfig', payload);
    }

    async function loadBackups() {
      const select = document.getElementById('backupIdSelect');
      if (!select) return;
      try {
        const res = await fetch(`/api/guild/${guildId}/backups`);
        const data = await res.json();
        if (!res.ok) throw new Error(data.error || 'Failed to load backups');
        const backups = data.backups || [];
        select.innerHTML = backups.length
          ? backups.map(b => `<option value="${b.id}">${b.id} • ${new Date(b.createdAt).toLocaleString()}</option>`).join('')
          : '<option value="">No backups found</option>';
      } catch (err) {
        window.axionToast(err.message, 'danger');
      }
    }

    async function createBackup(btn) {
      window.axionSetSaving(btn, true);
      try {
        const res = await fetch(`/api/guild/${guildId}/backups/create`, { method: 'POST' });
        const data = await res.json();
        if (!res.ok) throw new Error(data.error || 'Failed to create backup');
        window.axionToast(`Backup created: ${data.backup.id}`, 'ok');
        await loadBackups();
      } catch (err) {
        window.axionToast(err.message, 'danger');
      } finally {
        window.axionSetSaving(btn, false);
      }
    }

    async function restoreBackup(btn) {
      const backupId = val('backupIdSelect');
      if (!backupId) {
        window.axionToast('Select a backup first', 'warning');
        return;
      }
      window.axionSetSaving(btn, true);
      try {
        const res = await fetch(`/api/guild/${guildId}/backups/restore`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ backupId }),
        });
        const data = await res.json();
        if (!res.ok) throw new Error(data.error || 'Restore failed');
        window.axionToast(`Restored backup: ${backupId}`, 'ok');
        await loadAll();
      } catch (err) {
        window.axionToast(err.message, 'danger');
      } finally {
        window.axionSetSaving(btn, false);
      }
    }

    function renderChart(counts) {
      const chart = document.getElementById('case-chart');
      const keys = ['warn', 'timeout', 'kick', 'ban', 'other'];
      const max = Math.max(1, ...keys.map(k => counts[k] || 0));
      chart.innerHTML = keys.map(k => {
        const v = counts[k] || 0;
        const pct = Math.round((v / max) * 100);
        return `<div class="card"><h3>${k}</h3><div class="muted">${v}</div><div style="height:8px;background:#0b1220;border:1px solid #334155;border-radius:999px;margin-top:8px;"><div style="height:100%;width:${pct}%;background:linear-gradient(90deg,var(--brand),var(--brand-2));border-radius:999px;"></div></div></div>`;
      }).join('');
    }

    function renderActivity(activity) {
      const box = document.getElementById('activity-feed');
      if (!activity.length) {
        box.innerHTML = '<div class="card"><p class="muted">No recent moderation activity.</p></div>';
        return;
      }
      box.innerHTML = activity.map(a => {
        const when = a.timestamp ? new Date(a.timestamp).toLocaleString() : 'Unknown';
        return `<div class="card"><h3>${a.action.toUpperCase()} • ${a.type}</h3><p class="muted">User: ${a.userId} • Mod: ${a.moderator || 'Unknown'}</p><p>${a.reason || 'No reason'}</p><p class="muted">${when}</p></div>`;
      }).join('');
    }

    function renderHealth(summary) {
      const box = document.getElementById('health-summary');
      if (!box) return;
      const modules = summary.modules || {};
      box.innerHTML = [
        healthPill('Staff Roles', !!(summary.setup?.moderatorRoleId && summary.setup?.adminRoleId)),
        healthPill('Automod', !!modules.automodEnabled),
        healthPill('Anti-Nuke', !!modules.antiNukeEnabled),
        healthPill('Security Shield', !!modules.securityShieldEnabled),
        healthPill('Extra Owners', !!modules.extraOwnersEnabled),
        healthPill('Logging', !!modules.loggingEnabled),
        healthPill('Tickets', !!modules.ticketEnabled),
        healthPill('Suggestions', !!modules.suggestionEnabled),
        healthPill('Verification', !!modules.verificationEnabled),
      ].join('');
    }

    function renderPerformance(summary) {
      const chart = document.getElementById('case-chart');
      const perf = summary.performance || {};
      const totals = perf.totals || {};
      const slowest = perf.slowest || [];
      const recent = perf.recent || [];
      const topSlow = slowest.slice(0, 3).map(s => `${s.name}: ${s.avgMs}ms`).join('<br>') || 'No command data yet';
      const recentFail = recent.filter(r => !r.ok).length;
      chart.innerHTML = [
        `<div class="card"><h3>Avg Latency</h3><p class="muted">${totals.avgMs || 0} ms</p></div>`,
        `<div class="card"><h3>Total Commands</h3><p class="muted">${totals.count || 0}</p></div>`,
        `<div class="card"><h3>Failures</h3><p class="muted">${totals.failed || 0} (recent: ${recentFail})</p></div>`,
        `<div class="card"><h3>Slowest Commands</h3><p class="muted">${topSlow}</p></div>`
      ].join('');
    }

    async function loadAll() {
      try {
        const [metaRes, cfgRes, statsRes, activityRes, summaryRes] = await Promise.all([
          fetch(`/api/guild/${guildId}/meta`),
          fetch(`/api/guild/${guildId}/config`),
          fetch(`/api/guild/${guildId}/stats`),
          fetch(`/api/guild/${guildId}/activity?limit=12`),
          fetch(`/api/guild/${guildId}/summary`),
        ]);

        const meta = await metaRes.json();
        const cfg = await cfgRes.json();
        const stats = await statsRes.json();
        const activity = await activityRes.json();
        const summary = await summaryRes.json();

        const roles = meta.roles || [];
        const channels = meta.channels || [];

        fillSelect('moderatorRoleId', roles, cfg.roleConfig?.moderatorRoleId || '');
        fillSelect('adminRoleId', roles, cfg.roleConfig?.adminRoleId || '');
        fillSelect('welcomerChannelId', channels, cfg.welcomerConfig?.channelId || '');
        fillSelect('starboardChannelId', channels, cfg.starboardConfig?.channelId || '');
        fillSelect('modLog', channels, cfg.logConfig?.modLog || '');
        fillSelect('messageLog', channels, cfg.logConfig?.messageLog || '');

        document.getElementById('welcomerEnabled').value = String(!!cfg.welcomerConfig?.enabled);
        document.getElementById('welcomerMessage').value = cfg.welcomerConfig?.message || '';
        document.getElementById('starboardEnabled').value = String(!!cfg.starboardConfig?.enabled);
        document.getElementById('starboardThreshold').value = cfg.starboardConfig?.threshold || 3;
        document.getElementById('automodEnabled').value = String(!!cfg.automodConfig?.enabled);
        document.getElementById('automodPunishment').value = cfg.automodConfig?.punishment || 'warn';
        document.getElementById('automodAntiSpam').value = String(!!cfg.automodConfig?.antiSpam?.enabled);
        document.getElementById('automodMaxMessages').value = cfg.automodConfig?.antiSpam?.maxMessages || 5;
        document.getElementById('automodTimeWindow').value = Math.round((cfg.automodConfig?.antiSpam?.timeWindow || 5000) / 1000);
        document.getElementById('automodAntiInvite').value = String(!!cfg.automodConfig?.antiInvite?.enabled);
        document.getElementById('automodBlockedDomains').value = arrayToCsv(cfg.automodConfig?.blockedDomains || []);
        document.getElementById('automodRegexFilters').value = arrayToCsv(cfg.automodConfig?.regexFilters || []);
        document.getElementById('automodAntiCaps').value = String(!!cfg.automodConfig?.antiCaps?.enabled);
        document.getElementById('automodCapsThreshold').value = cfg.automodConfig?.antiCaps?.threshold || 70;
        document.getElementById('automodAntiMention').value = String(!!cfg.automodConfig?.antiMassMention?.enabled);
        document.getElementById('automodMaxMentions').value = cfg.automodConfig?.antiMassMention?.max || 5;
        document.getElementById('automodAntiEmoji').value = String(!!cfg.automodConfig?.antiEmoji?.enabled);
        document.getElementById('automodMaxEmojis').value = cfg.automodConfig?.antiEmoji?.max || 10;
        document.getElementById('automodBypassAdmins').value = String(cfg.automodConfig?.bypass?.admins !== false);
        document.getElementById('automodBypassModerators').value = String(cfg.automodConfig?.bypass?.moderators !== false);
        document.getElementById('automodBypassBots').value = String(cfg.automodConfig?.bypass?.bots !== false);
        document.getElementById('antiNukeEnabled').value = String(!!cfg.antiNukeConfig?.enabled);
        document.getElementById('antiNukePreset').value = cfg.antiNukeConfig?.preset || 'medium';
        document.getElementById('antiNukeThreshold').value = cfg.antiNukeConfig?.threshold || 3;
        document.getElementById('antiNukeWindow').value = Math.round((cfg.antiNukeConfig?.intervalMs || 10000) / 1000);
        document.getElementById('antiNukeAction').value = cfg.antiNukeConfig?.action || 'remove_roles';
        document.getElementById('antiNukeApplyToAdmins').value = String(!!cfg.antiNukeConfig?.applyToAdmins);
        document.getElementById('antiNukeUsers').value = arrayToCsv(cfg.antiNukeConfig?.whitelistedUsers || []);
        document.getElementById('antiNukeRoles').value = arrayToCsv(cfg.antiNukeConfig?.whitelistedRoles || []);
        document.getElementById('securityEnabled').value = String(!!cfg.securityShieldConfig?.enabled);
        document.getElementById('securityAntiAltEnabled').value = String(!!cfg.securityShieldConfig?.antiAlt?.enabled);
        document.getElementById('securityMinAge').value = cfg.securityShieldConfig?.antiAlt?.minAccountAgeDays || 3;
        document.getElementById('securityAntiAltAction').value = cfg.securityShieldConfig?.antiAlt?.action || 'kick';
        document.getElementById('securityQuarantineRoleId').value = cfg.securityShieldConfig?.quarantineRoleId || '';
        document.getElementById('securityJoinGuardEnabled').value = String(!!cfg.securityShieldConfig?.joinGuard?.enabled);
        document.getElementById('securityJoinThreshold').value = cfg.securityShieldConfig?.joinGuard?.maxJoins || 8;
        document.getElementById('securityJoinWindow').value = Math.round((cfg.securityShieldConfig?.joinGuard?.windowMs || 15000) / 1000);
        document.getElementById('securityJoinAction').value = cfg.securityShieldConfig?.joinGuard?.action || 'alert';
        document.getElementById('extraOwnersUserIds').value = arrayToCsv(cfg.extraOwnersConfig?.userIds || []);
        document.getElementById('autoResponderEnabled').value = String(!!cfg.autoResponderConfig?.enabled);
        document.getElementById('autoResponderRules').value = JSON.stringify(cfg.autoResponderConfig?.responders || [], null, 2);
        document.getElementById('tagsMap').value = JSON.stringify(cfg.tagsConfig?.tags || {}, null, 2);
        document.getElementById('reactionRoleConfigJson').value = JSON.stringify(cfg.reactionRoleConfig || {}, null, 2);
        document.getElementById('suggestionsEnabled').value = String(!!cfg.suggestionConfig?.enabled);
        document.getElementById('verificationEnabled').value = String(!!cfg.verifyConfig?.enabled);
        document.getElementById('verificationMode').value = cfg.verifyConfig?.mode || 'button';
        document.getElementById('verificationQuestion').value = cfg.verifyConfig?.humanCheck?.question || 'Type YES to verify.';
        document.getElementById('verificationAnswer').value = cfg.verifyConfig?.humanCheck?.answer || 'YES';
        document.getElementById('ticketEnabled').value = String(!!cfg.ticketConfig?.enabled);

        document.getElementById('stat-cases').textContent = stats.caseCount || 0;
        document.getElementById('stat-warnings').textContent = stats.warningCount || 0;
        document.getElementById('stat-tickets').textContent = stats.openTickets || 0;

        renderChart(stats.caseTypeCounts || {});
        renderActivity(activity.activity || []);
        renderHealth(summary || {});
        renderPerformance(summary || {});
        await loadBackups();
      } catch (_err) {
        window.axionToast('Failed to load dashboard data', 'warning');
      }
    }

    loadAll();
  </script>
</body>
</html>
