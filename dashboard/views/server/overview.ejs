<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= guild.name %> · Axion</title>
  <link rel="icon" type="image/png" href="/img/axion-logo.png">
  <link rel="stylesheet" href="/css/main.css?v=20260329-7">
</head>
<body>
  <main class="container layout">
    <aside class="sidebar">
      <div class="logo-wrap">
        <div class="logo-left">
          <img class="logo" style="width:24px;height:24px;max-width:24px;max-height:24px;min-width:24px;min-height:24px;object-fit:cover;border-radius:6px;" src="/img/axion-logo.png" onerror="this.onerror=null;this.src='/img/axion-logo.svg';" alt="Axion">
          <div class="brand-text">
            <div class="brand-title">AXION</div>
            <div class="brand-sub"><%= guild.name %></div>
          </div>
        </div>
        <button class="icon-btn" data-sidebar-toggle>☰</button>
      </div>
      <nav class="nav">
        <a class="nav-link" href="/dashboard"><i>🏠</i><span>Servers</span></a>
        <a class="nav-link active" href="#"><i>⚙️</i><span>Config</span></a>
      </nav>
      <div class="theme-picker">
        <button class="theme-btn" data-theme="default">Default</button>
        <button class="theme-btn" data-theme="neon">Neon</button>
        <button class="theme-btn" data-theme="sunset">Sunset</button>
        <button class="theme-btn" data-theme="emerald">Emerald</button>
      </div>
    </aside>

    <section class="main">
      <section class="hero">
        <h1><%= guild.name %> Configuration</h1>
        <p>Manage your server modules, permissions, and moderation setup.</p>
        <div class="actions"><a class="btn secondary" href="/dashboard">Back</a></div>
      </section>

      <section class="card compact-overview">
        <div class="compact-overview-item">
          <span>Total cases</span>
          <strong id="stat-cases">0</strong>
        </div>
        <div class="compact-overview-item">
          <span>Total warnings</span>
          <strong id="stat-warnings">0</strong>
        </div>
        <div class="compact-overview-item">
          <span>Open tickets</span>
          <strong id="stat-tickets">0</strong>
        </div>
      </section>

      <section class="card">
        <h2>Moderation Trend</h2>
        <div id="case-chart" class="grid cols-3"></div>
      </section>

      <section class="card">
        <h2>Modules</h2>
        <div class="tab-row" data-tab-group="modules">
          <button class="tab-btn active" data-tab-group="modules" data-tab-btn="roles">Roles</button>
          <button class="tab-btn" data-tab-group="modules" data-tab-btn="welcomer">Welcomer</button>
          <button class="tab-btn" data-tab-group="modules" data-tab-btn="starboard">Starboard</button>
          <button class="tab-btn" data-tab-group="modules" data-tab-btn="automod">Automod</button>
          <button class="tab-btn" data-tab-group="modules" data-tab-btn="logging">Logging</button>
        </div>
      </section>

      <section class="card tab-panel active" data-tab-group="modules" data-tab-panel="roles">
        <h2>Role Configuration</h2>
        <label>Moderator Role</label><select id="moderatorRoleId"></select>
        <label>Admin Role</label><select id="adminRoleId"></select>
        <button class="btn" onclick="handleSave(this,'roleConfig',{ moderatorRoleId: val('moderatorRoleId'), adminRoleId: val('adminRoleId') })">Save Roles</button>
      </section>

      <section class="card tab-panel" data-tab-group="modules" data-tab-panel="welcomer">
        <h2>Welcomer</h2>
        <label>Enabled</label><select id="welcomerEnabled"><option value="true">true</option><option value="false">false</option></select>
        <label>Channel</label><select id="welcomerChannelId"></select>
        <label>Message</label><textarea id="welcomerMessage" rows="3" placeholder="Welcome {user} to {server}!"></textarea>
        <button class="btn" onclick="handleSave(this,'welcomerConfig',{ enabled: boolVal('welcomerEnabled'), channelId: val('welcomerChannelId'), message: val('welcomerMessage') })">Save Welcomer</button>
      </section>

      <section class="card tab-panel" data-tab-group="modules" data-tab-panel="starboard">
        <h2>Starboard</h2>
        <label>Enabled</label><select id="starboardEnabled"><option value="true">true</option><option value="false">false</option></select>
        <label>Channel</label><select id="starboardChannelId"></select>
        <label>Threshold</label><input id="starboardThreshold" type="number" min="1" max="20" value="3" />
        <button class="btn" onclick="handleSave(this,'starboardConfig',{ enabled: boolVal('starboardEnabled'), channelId: val('starboardChannelId'), threshold: numVal('starboardThreshold') })">Save Starboard</button>
      </section>

      <section class="card tab-panel" data-tab-group="modules" data-tab-panel="automod">
        <h2>Automod</h2>
        <label>Enabled</label><select id="automodEnabled"><option value="true">true</option><option value="false">false</option></select>
        <button class="btn" onclick="handleSave(this,'automodConfig',{ enabled: boolVal('automodEnabled') })">Save Automod</button>
      </section>

      <section class="card tab-panel" data-tab-group="modules" data-tab-panel="logging">
        <h2>Logging</h2>
        <label>Moderation Log Channel</label><select id="modLog"></select>
        <label>Message Log Channel</label><select id="messageLog"></select>
        <button class="btn" onclick="handleSave(this,'logConfig',{ modLog: val('modLog'), messageLog: val('messageLog') })">Save Logging</button>
      </section>

      <section class="card">
        <h2>Recent Activity</h2>
        <div id="activity-feed" class="grid"></div>
      </section>
    </section>
  </main>

  <script src="/js/theme.js?v=20260329-7"></script>
  <script src="/js/ui.js?v=20260329-7"></script>
  <script>
    const guildId = '<%= guild.id %>';

    function val(id) { return document.getElementById(id).value; }
    function boolVal(id) { return document.getElementById(id).value === 'true'; }
    function numVal(id) { return Number(document.getElementById(id).value); }

    function fillSelect(id, options, selected) {
      const el = document.getElementById(id);
      if (!el) return;
      const base = '<option value="">Not set</option>';
      el.innerHTML = base + options.map(o => `<option value="${o.id}">${o.name}</option>`).join('');
      if (selected) el.value = selected;
    }

    async function handleSave(btn, section, data) {
      window.axionSetSaving(btn, true);
      try {
        const res = await fetch(`/api/guild/${guildId}/config`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ section, data }),
        });
        const payload = await res.json();
        if (!res.ok) throw new Error(payload.error || 'Save failed');
        window.axionToast(`${section} saved`, 'ok');
      } catch (err) {
        window.axionToast(err.message, 'danger');
      } finally {
        window.axionSetSaving(btn, false);
      }
    }

    function renderChart(counts) {
      const chart = document.getElementById('case-chart');
      const keys = ['warn', 'timeout', 'kick', 'ban', 'other'];
      const max = Math.max(1, ...keys.map(k => counts[k] || 0));
      chart.innerHTML = keys.map(k => {
        const v = counts[k] || 0;
        const pct = Math.round((v / max) * 100);
        return `<div class="card"><h3>${k}</h3><div class="muted">${v}</div><div style="height:8px;background:#0b1220;border:1px solid #334155;border-radius:999px;margin-top:8px;"><div style="height:100%;width:${pct}%;background:linear-gradient(90deg,var(--brand),var(--brand-2));border-radius:999px;"></div></div></div>`;
      }).join('');
    }

    function renderActivity(activity) {
      const box = document.getElementById('activity-feed');
      if (!activity.length) {
        box.innerHTML = '<div class="card"><p class="muted">No recent moderation activity.</p></div>';
        return;
      }
      box.innerHTML = activity.map(a => {
        const when = a.timestamp ? new Date(a.timestamp).toLocaleString() : 'Unknown';
        return `<div class="card"><h3>${a.action.toUpperCase()} • ${a.type}</h3><p class="muted">User: ${a.userId} • Mod: ${a.moderator || 'Unknown'}</p><p>${a.reason || 'No reason'}</p><p class="muted">${when}</p></div>`;
      }).join('');
    }

    async function loadAll() {
      try {
        const [metaRes, cfgRes, statsRes, activityRes] = await Promise.all([
          fetch(`/api/guild/${guildId}/meta`),
          fetch(`/api/guild/${guildId}/config`),
          fetch(`/api/guild/${guildId}/stats`),
          fetch(`/api/guild/${guildId}/activity?limit=12`),
        ]);

        const meta = await metaRes.json();
        const cfg = await cfgRes.json();
        const stats = await statsRes.json();
        const activity = await activityRes.json();

        const roles = meta.roles || [];
        const channels = meta.channels || [];

        fillSelect('moderatorRoleId', roles, cfg.roleConfig?.moderatorRoleId || '');
        fillSelect('adminRoleId', roles, cfg.roleConfig?.adminRoleId || '');
        fillSelect('welcomerChannelId', channels, cfg.welcomerConfig?.channelId || '');
        fillSelect('starboardChannelId', channels, cfg.starboardConfig?.channelId || '');
        fillSelect('modLog', channels, cfg.logConfig?.modLog || '');
        fillSelect('messageLog', channels, cfg.logConfig?.messageLog || '');

        document.getElementById('welcomerEnabled').value = String(!!cfg.welcomerConfig?.enabled);
        document.getElementById('welcomerMessage').value = cfg.welcomerConfig?.message || '';
        document.getElementById('starboardEnabled').value = String(!!cfg.starboardConfig?.enabled);
        document.getElementById('starboardThreshold').value = cfg.starboardConfig?.threshold || 3;
        document.getElementById('automodEnabled').value = String(!!cfg.automodConfig?.enabled);

        document.getElementById('stat-cases').textContent = stats.caseCount || 0;
        document.getElementById('stat-warnings').textContent = stats.warningCount || 0;
        document.getElementById('stat-tickets').textContent = stats.openTickets || 0;

        renderChart(stats.caseTypeCounts || {});
        renderActivity(activity.activity || []);
      } catch (_err) {
        window.axionToast('Failed to load dashboard data', 'warning');
      }
    }

    loadAll();
  </script>
</body>
</html>
