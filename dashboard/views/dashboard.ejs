<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Axion Dashboard</title>
  <link rel="icon" type="image/png" href="/img/axion-logo.png">
  <link rel="stylesheet" href="/css/main.css?v=20260329-7">
</head>
<body>
  <main class="container layout">
    <aside class="sidebar">
      <div class="logo-wrap">
        <div class="logo-left">
          <img class="logo" style="width:24px;height:24px;max-width:24px;max-height:24px;min-width:24px;min-height:24px;object-fit:cover;border-radius:6px;" src="/img/axion-logo.png" onerror="this.onerror=null;this.src='/img/axion-logo.svg';" alt="Axion">
          <div class="brand-text">
            <div class="brand-title">AXION</div>
            <div class="brand-sub">Welcome, <%= user.username %></div>
          </div>
        </div>
        <button class="icon-btn" data-sidebar-toggle>☰</button>
      </div>
      <nav class="nav">
        <a class="nav-link active" href="/dashboard"><i>🏠</i><span>Servers</span></a>
        <a class="nav-link" href="/"><i>✨</i><span>Home</span></a>
        <a class="nav-link" href="/logout"><i>🚪</i><span>Logout</span></a>
      </nav>
      <div class="theme-picker">
        <button class="theme-btn" data-theme="default">Default</button>
        <button class="theme-btn" data-theme="neon">Neon</button>
        <button class="theme-btn" data-theme="sunset">Sunset</button>
        <button class="theme-btn" data-theme="emerald">Emerald</button>
      </div>
      <div class="sidebar-footer">Axion UI vNext</div>
    </aside>

    <section class="main">
      <section class="hero">
        <h1>Server Management</h1>
        <p>Select a server to open its configuration workspace.</p>
      </section>

      <% if (typeof noAuthMode !== 'undefined' && noAuthMode) { %>
        <div class="card warning">⚠️ NO_AUTH mode enabled. Anyone with URL access can manage settings.</div>
      <% } %>

      <section class="card compact-overview">
        <div class="compact-overview-item">
          <span>Total servers</span>
          <strong id="stat-total">0</strong>
        </div>
        <div class="compact-overview-item">
          <span>Connected</span>
          <strong id="stat-connected">0</strong>
        </div>
        <div class="compact-overview-item">
          <span>Pending invite</span>
          <strong id="stat-pending">0</strong>
        </div>
      </section>

      <div id="guilds">Loading...</div>
    </section>
  </main>
  <script src="/js/theme.js?v=20260329-7"></script>
  <script src="/js/ui.js?v=20260329-7"></script>
  <script src="/js/dashboard.js?v=20260329-7"></script>
</body>
</html>
